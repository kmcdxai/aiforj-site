# ═══════════════════════════════════════════════════
# AIForj Environment Variables
# Copy this file to .env.local and fill in your values
# ═══════════════════════════════════════════════════

# Stripe Keys (from https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=sk_test_YOUR_SECRET_KEY_HERE
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_PUBLISHABLE_KEY_HERE

# Stripe Price ID (from Product Catalog → AIForj Premium)
STRIPE_PRICE_ID=price_1T8UaEPiX1op9rgKojfYgU3R

# Your domain
NEXT_PUBLIC_DOMAIN=https://aiforj.com

# Stripe Webhook Secret (set up later in Stripe Dashboard → Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE
