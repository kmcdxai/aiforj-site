# ═══════════════════════════════════════════════════
# AIForj Environment Variables
# Copy this file to .env.local and fill in your values
# ═══════════════════════════════════════════════════

# Stripe Keys
STRIPE_SECRET_KEY=sk_test_YOUR_SECRET_KEY_HERE
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_PUBLISHABLE_KEY_HERE

# Stripe Price IDs
STRIPE_PRICE_PREMIUM_MONTHLY=price_YOUR_PREMIUM_MONTHLY_ID
STRIPE_PRICE_FAMILY_MONTHLY=price_YOUR_FAMILY_MONTHLY_ID
STRIPE_PRICE_GIFT_MONTH=price_YOUR_GIFT_MONTH_ID
STRIPE_PRICE_CLINICIAN_MONTHLY=price_YOUR_CLINICIAN_MONTHLY_ID
STRIPE_PRICE_ORG_PILOT_MONTHLY=price_YOUR_ORG_PILOT_MONTHLY_ID

# Legacy aliases still supported by older API route names
STRIPE_PRICE_ID=
STRIPE_FAMILY_PRICE_ID=
STRIPE_SPONSOR_PRICE_ID=

# Your domain
NEXT_PUBLIC_DOMAIN=https://aiforj.com

# Stripe Webhook Secret (set up later in Stripe Dashboard → Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# Signed local activation links
ENTITLEMENT_SECRET=use_at_least_32_random_bytes_here

# Feature flags default to enabled unless set to false/0/off/no
NEXT_PUBLIC_ENABLE_PRIVACY_METRICS=true
NEXT_PUBLIC_ENABLE_SHARE_ENGINE=true
NEXT_PUBLIC_ENABLE_PREMIUM_CHECKOUT=true
NEXT_PUBLIC_ENABLE_DAILY_CHECKIN=true
NEXT_PUBLIC_ENABLE_ORG_REPORTING=true

# Optional aggregate reporting store for org metrics (JSON array or NDJSON)
# Example: .data/aggregate-metrics.ndjson
AIFORJ_AGGREGATE_METRICS_FILE=

# Durable Vercel Blob store for aggregate-only org reporting
BLOB_READ_WRITE_TOKEN=
AIFORJ_ORG_REPORTING_PREFIX=organization-reporting
