{
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "www.aiforj.com" }],
      "destination": "https://aiforj.com/",
      "permanent": true
    },
    {
      "source": "/:path(.*)",
      "has": [{ "type": "host", "value": "www.aiforj.com" }],
      "destination": "https://aiforj.com/:path",
      "permanent": true
    }
  ]
}
